import React from "react";
import PickupBarcode from "./components/PickupBarcode";

function QRCodePickup({ orders }) {

  if (!orders.length) {
    return <p>No active orders to generate pickup barcodes.</p>;
  }

  return (
    <div>
      <h2>Customer Pickup Barcodes</h2>
      <p>Customers can scan these at check-in or enter the pickup code manually.</p>

      {orders.map(order => {
        const pickupCode = order.pickupCode || "";

        return (
          <div key={order.id} style={cardStyle}>

            <h3>{order.customerId}</h3>

            <p>Order Item: {order.item}</p>
            <p>Quantity: {order.quantity}</p>

            <PickupBarcode
              value={pickupCode}
              helperText="Scan this barcode at the dispensary check-in."
            />

          </div>
        );

      })}
    </div>
  );
}

const cardStyle = {
  padding:"20px",
  marginBottom:"20px",
  borderRadius:"10px",
  border:"1px solid #ddd",
  background:"white"
};

export default QRCodePickup;
